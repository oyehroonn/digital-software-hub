# DSM frontend env — copy to .env.local (gitignored) and adjust.
# NOTE: every VITE_* value is PUBLIC (inlined into the bundle). Never put the
# codex-proxy key, Simli key, or Apps Script secret here — those live only on
# the server behind the proxy routes.

# VPS Flask DSM-3D API base (unstable backend)
VITE_API_BASE=http://localhost:5051

# Public Ecommerce/Analytics Apps Script exec URL (stable backend, telemetry)
VITE_ECOMMERCE_API=https://script.google.com/macros/s/AKfycbwn05r3WVqMpV4Tftn4n1qEs7I10cu3Z8S306jMXaXXCClxizt2EfOUSKa9cTha6pPD/exec

# Store name stamped on telemetry rows
VITE_STORE_NAME=DSM

# Same-origin proxy base for the codex-proxy LLM. The server route at this path
# injects the Bearer key and forwards to https://open.techrealm.ai/v1
VITE_LLM_PROXY_BASE=/api/llm
VITE_LLM_MODEL=gpt-5.4

# Simli Talking Advisor (feature 07) — served by the isolated Simli proxy that
# injects the apiKey + faceId server-side, exposed on the dsm-api origin.
VITE_SIMLI_HEALTH_URL=https://dsm-api.techrealm.ai/api/simli/health
VITE_SIMLI_PROXY_BASE=https://dsm-api.techrealm.ai/api/simli

# Checkout — instant email proxy (forwards to the STABLE email Apps Script;
# the mail key is injected server-side in 3dstuff/api.py → /api/email).
# Defaults to {VITE_API_BASE}/api/email when unset.
VITE_EMAIL_PROXY_URL=https://dsm-api.techrealm.ai/api/email

# Checkout — LICENSING path redirects here to complete the purchase.
# FLAG: assumed base derived from the DSM socials/marketing domain; confirm the
# real licensing storefront host + product-URL pattern (see src/lib/legacyStore.ts).
VITE_OLD_WEB_BASE=https://www.digitalsoftwaremarket.com

# Checkout — DSM OWN-product path books a meeting via this scheduling link.
# FLAG: placeholder Calendly URL; replace with the real DSM scheduling link.
VITE_CALENDLY_URL=https://calendly.com/dsm/intro
