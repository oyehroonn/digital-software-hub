# DSM frontend env — copy to .env.local (gitignored) and adjust.
# NOTE: every VITE_* value is PUBLIC (inlined into the bundle). Never put the
# codex-proxy key, Simli key, or Apps Script secret here — those live only on
# the server behind the proxy routes.

# VPS Flask DSM-3D API base (unstable backend)
VITE_API_BASE=http://localhost:5051

# Public Ecommerce/Analytics Apps Script exec URL (stable backend, telemetry)
VITE_ECOMMERCE_API=https://script.google.com/macros/s/AKfycbwn05r3WVqMpV4Tftn4n1qEs7I10cu3Z8S306jMXaXXCClxizt2EfOUSKa9cTha6pPD/exec

# Store name stamped on telemetry rows
VITE_STORE_NAME=DSM

# Same-origin proxy base for the codex-proxy LLM. The server route at this path
# injects the Bearer key and forwards to https://open.techrealm.ai/v1
VITE_LLM_PROXY_BASE=/api/llm
VITE_LLM_MODEL=gpt-5.4

# Simli health endpoint (same-origin proxy recommended)
VITE_SIMLI_HEALTH_URL=/api/simli/health
