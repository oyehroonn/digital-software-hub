# Production build env (used by `vite build` on Cloudflare). Mirrors .env.local
# so the deployed site talks to the live VPS API, not localhost.
VITE_API_BASE=https://dsm-api.techrealm.ai
VITE_SIMLI_PROXY_BASE=https://dsm-api.techrealm.ai/api/simli
VITE_SIMLI_HEALTH_URL=https://dsm-api.techrealm.ai/api/simli/health
VITE_LLM_PROXY_BASE=https://dsm-api.techrealm.ai/api/llm
VITE_LLM_MODEL=gpt-5.4
VITE_EMAIL_PROXY_URL=https://dsm-api.techrealm.ai/api/email
VITE_CALENDLY_URL=https://calendly.com/dsm/intro
VITE_OLD_WEB_BASE=https://www.digitalsoftwaremarkett.com
