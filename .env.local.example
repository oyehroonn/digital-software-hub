# DSM frontend env — copy to `.env.local` (gitignored) and adjust.
#
# IMPORTANT: every VITE_* value below is PUBLIC — Vite inlines it into the
# client bundle. NEVER put a secret here (codex-proxy key, Simli key, Apps
# Script secret). Those live ONLY on the server behind the same-origin proxy
# routes (/api/llm, /api/simli) or in the local admin bridge.
#
# The app is designed to build and run with NONE of these set: the stable core
# (cached browse, cart, checkout, telemetry) and the static Smart Search index
# keep working, and every AI feature simply self-hides when its unstable backend
# is unreachable (the resilience contract).

# ── UNSTABLE: VPS Flask DSM-3D API base (products / search / boxes) ───────────
# When unset, defaults to http://localhost:5051. Smart Search falls back to the
# bundled static catalogue index when this is down.
VITE_API_BASE=http://localhost:5051

# ── STABLE: public Ecommerce/Analytics Apps Script exec URL (telemetry+orders) ─
# Not a secret — this is a public web-app endpoint. Telemetry posts here no-cors.
VITE_ECOMMERCE_API=https://script.google.com/macros/s/AKfycbwn05r3WVqMpV4Tftn4n1qEs7I10cu3Z8S306jMXaXXCClxizt2EfOUSKa9cTha6pPD/exec

# Store name stamped on telemetry / order rows.
VITE_STORE_NAME=DSM

# ── UNSTABLE: codex-proxy (LLM) — reached ONLY via a same-origin proxy route ──
# The server route at this base injects `Authorization: Bearer <key>` and
# forwards to https://open.techrealm.ai/v1. The key is NEVER in this file.
VITE_LLM_PROXY_BASE=/api/llm
VITE_LLM_MODEL=gpt-5.4

# ── UNSTABLE: Simli avatar (feature 07 Talking Advisor) ──────────────────────
# Served by the isolated Simli proxy (systemd `simli-proxy` on the VPS, port
# 5201) which injects the Simli apiKey + faceId SERVER-SIDE and is exposed on
# the live dsm-api origin. No secret is ever inlined here. Health + session base:
VITE_SIMLI_HEALTH_URL=https://dsm-api.techrealm.ai/api/simli/health
VITE_SIMLI_PROXY_BASE=https://dsm-api.techrealm.ai/api/simli
# (Local same-origin dev alternative: /api/simli/health and /api/simli)

# Optional: local mail bridge URL (admin app sidecar that shells mailcli).
# Default http://localhost:8787/mail. Used for quote/lead emails + callback booking.
# VITE_MAIL_BRIDGE_URL=http://localhost:8787/mail

# Optional: where sales leads / callback bookings are emailed. Default it@aljashtrading.com.
# VITE_SALES_LEAD_INBOX=it@aljashtrading.com
