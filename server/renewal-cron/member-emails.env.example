# DSM member auto-emails — environment (copy to /etc/dsm/member-emails.env, chmod 600)
# NOTHING in here is committed. These are the ONLY secrets the cron needs.

# STABLE Ecommerce Apps Script (orders + members/telemetry source of truth).
# Public web-app URL is not a secret; the shared secret authenticates the READ
# actions (action=orders / action=members / action=telemetry).
DSM_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwn05r3WVqMpV4Tftn4n1qEs7I10cu3Z8S306jMXaXXCClxizt2EfOUSKa9cTha6pPD/exec
DSM_APPS_SCRIPT_SECRET=REPLACE_WITH_APPS_SCRIPT_SECRET

# STABLE email path. The cron shells out to the SAME mailcli the site's mail
# bridge uses, so no new mail secret is introduced. Point this at the deployed
# mailcli.py and (optionally) choose a sender endpoint (default|personal|techrealm).
DSM_MAILCLI_PATH=/opt/dsm/mail/mailcli.py
DSM_MAIL_ENDPOINT=

# Branding / links used in the email bodies.
DSM_STORE_NAME=DSM
DSM_STORE_URL=https://digitalsoftwaremarket.com/store
DSM_MEMBER_DISCOUNT_PCT=10

# Reminder windows in days-before-expiry (each fires once per licence).
DSM_REMINDER_WINDOWS=30,7,1

# Idempotency ledger + launch feed (defaults are fine on systemd; see units).
# DSM_STATE_PATH=/var/lib/dsm/member-emails-state.json
# DSM_LAUNCHES_PATH=/opt/dsm/renewal-cron/launches.json

# Set to 1 to log what WOULD send without sending (safe first run).
DSM_DRY_RUN=0
